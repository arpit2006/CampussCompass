<%- include('partials/header') %>
<%- include('partials/navbar') %>

<main class="auth-page">
  <div class="auth-container">
    <div class="auth-split-layout">
      
      <!-- Form Side -->
      <div class="auth-form-side">
        <div class="auth-card">
          <div class="auth-header">
            <div class="auth-logo-circle">
              <i class="fa-solid fa-compass"></i>
            </div>
            <h2>Welcome Back</h2>
            <p>Log in to access your dashboard and resume your roadmap</p>
          </div>

          <% if (typeof error !== 'undefined' && error) { %>
            <div class="alert alert-danger">
              <i class="fa-solid fa-triangle-exclamation"></i>
              <span><%= error %></span>
            </div>
          <% } %>

          <% if (typeof success !== 'undefined' && success) { %>
            <div class="alert alert-success">
              <i class="fa-solid fa-circle-check"></i>
              <span><%= success %></span>
            </div>
          <% } %>

          <form action="/login" method="POST" class="auth-form">
            <div class="form-group">
              <label for="email">Email Address</label>
              <div class="input-wrapper">
                <i class="fa-solid fa-envelope"></i>
                <input type="email" id="email" name="email" placeholder="student@college.edu" required>
              </div>
            </div>

            <div class="form-group">
              <label for="password">Password</label>
              <div class="input-wrapper">
                <i class="fa-solid fa-lock"></i>
                <input type="password" id="password" name="password" placeholder="••••••••" required>
              </div>
            </div>

            <button type="submit" class="btn btn-primary btn-full">Log In <i class="fa-solid fa-right-to-bracket"></i></button>
          </form>

          <div class="auth-divider">
            <span>or connect with</span>
          </div>

          <div class="social-auth-buttons">
            <a href="/auth/github" class="btn btn-social-login btn-github-login">
              <i class="fa-brands fa-github"></i> GitHub
            </a>
            <a href="/auth/leetcode" class="btn btn-social-login btn-leetcode-login">
              <i class="fa-solid fa-code"></i> LeetCode
            </a>
          </div>

          <div class="auth-footer">
            <p>New to CampusCompass? <a href="/register" class="text-link">Create an account</a></p>
          </div>
        </div>
      </div>

      <!-- Info/Promo Side (Fills the blank space) -->
      <div class="auth-info-side">
        <div class="auth-info-content">
          <span class="info-tag">CampusCompass</span>
          <h2>A structured plan, built for students.</h2>
          <p>Ditch the confusion of fragmented online tutorials and AI-generated advice. CampusCompass maps out your studies semester-by-semester.</p>
          
          <div class="info-features">
            <div class="info-feature-item">
              <div class="info-feature-icon"><i class="fa-solid fa-bolt"></i></div>
              <div>
                <h5>Zero-Config Setup</h5>
                <p>No complex MongoDB server database to configure. Works instantly out of the box.</p>
              </div>
            </div>
            
            <div class="info-feature-item">
              <div class="info-feature-icon"><i class="fa-solid fa-map-location-dot"></i></div>
              <div>
                <h5>Focused Learning</h5>
                <p>Curated roadmaps covering core software developer tracks, cybersecurity, and data science.</p>
              </div>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</main>

<%- include('partials/footer') %>
