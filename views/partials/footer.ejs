        <span>Campus<span class="text-gradient">Compass</span></span>
      </a>
      <p class="footer-description">
        Navigating students through their college journey by highlighting what features, skills, and roadmaps to focus on.
      </p>
      <div class="footer-socials">
        <a href="https://github.com" target="_blank" aria-label="GitHub"><i class="fa-brands fa-github"></i></a>
        <a href="https://linkedin.com" target="_blank" aria-label="LinkedIn"><i class="fa-brands fa-linkedin"></i></a>
        <a href="https://twitter.com" target="_blank" aria-label="Twitter"><i class="fa-brands fa-x-twitter"></i></a>
      </div>
    </div>
    
    <div class="footer-links-section">
      <h4>Navigation</h4>
      <ul>
        <li><a href="/#explore">Explore Roadmaps</a></li>
        <li><a href="/#how-it-works">How It Works</a></li>
        <li><a href="/resources">Resources Hub</a></li>
        <li><a href="/#testimonials">Feedback Hub</a></li>
        <li><a href="/#faq">FAQ</a></li>
      </ul>
    </div>

    <div class="footer-links-section">
      <h4>Resources</h4>
      <ul>
        <li><a href="/register">Join CampusCompass</a></li>
        <li><a href="/login">Account Access</a></li>
        <li><a href="https://github.com" target="_blank">Open Source Hub</a></li>
        <li><a href="/privacy">Privacy Policy</a></li>
        <li><a href="/terms">Terms &amp; Conditions</a></li>
      </ul>
    </div>

    <div class="footer-links-section footer-badge-col">
      <h4>Community &amp; Tech</h4>
      <div class="footer-badge-list">
        <span class="f-badge"><i class="fa-solid fa-code-pull-request"></i> PRs Welcoming</span>
        <span class="f-badge"><i class="fa-brands fa-node-js"></i> Node.js &amp; EJS</span>
