<%- include('partials/header') %>
<%- include('partials/navbar') %>

<main class="profile-setup-page">
  <div class="profile-setup-container">
    <div class="profile-setup-card">
      <div class="profile-setup-header">
        <h2>Complete Your Student Profile</h2>
        <p>Tell us a bit about your college life and career goals to initialize your roadmap.</p>
      </div>

      <% if (typeof error !== 'undefined' && error) { %>
        <div class="alert alert-danger">
          <i class="fa-solid fa-triangle-exclamation"></i>
          <span><%= error %></span>
        </div>
      <% } %>

      <form action="/profile/setup" method="POST" class="setup-form">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <div class="form-grid">
          
          <!-- Full Name -->
          <div class="form-group">
            <label for="fullName">Full Name <span class="required">*</span></label>
            <div class="input-wrapper">
              <i class="fa-solid fa-user"></i>
              <input type="text" id="fullName" name="fullName" placeholder="e.g. Amit Patel" required>
            </div>
          </div>

          <!-- College Name -->
          <div class="form-group">
            <label for="collegeName">College Name <span class="required">*</span></label>
            <div class="input-wrapper">
              <i class="fa-solid fa-building-columns"></i>
              <input type="text" id="collegeName" name="collegeName" placeholder="e.g. Delhi Technological University" required>
            </div>
          </div>

          <!-- Branch -->
          <div class="form-group">
            <label for="branch">Branch/Major <span class="required">*</span></label>
            <div class="input-wrapper">
              <i class="fa-solid fa-graduation-cap"></i>
              <input type="text" id="branch" name="branch" placeholder="e.g. Computer Science" required>
            </div>
          </div>

          <!-- Current Year -->
          <div class="form-group">
            <label for="currentYear">Current Year <span class="required">*</span></label>
            <div class="input-wrapper">
              <i class="fa-solid fa-calendar-days"></i>
              <select id="currentYear" name="currentYear" required>
                <option value="" disabled selected>Select current year</option>
                <option value="1st Year">1st Year</option>
                <option value="2nd Year">2nd Year</option>
                <option value="3rd Year">3rd Year</option>
                <option value="4th Year">4th Year</option>
              </select>
            </div>
          </div>

          <!-- CGPA -->
          <div class="form-group">
            <label for="cgpa">Current CGPA</label>
            <div class="input-wrapper">
              <i class="fa-solid fa-chart-bar"></i>
              <input type="number" id="cgpa" name="cgpa" placeholder="e.g. 8.5" step="0.01" min="0" max="10">
            </div>
          </div>

          <!-- Career Goal -->
          <div class="form-group">
            <label for="careerGoal">Target Career Goal <span class="required">*</span></label>
            <div class="input-wrapper">
              <i class="fa-solid fa-bullseye"></i>
              <select id="careerGoal" name="careerGoal" required>
                <option value="" disabled selected>Select career track</option>
                <option value="Software Engineer">Software Engineer</option>
                <option value="Web Developer">Web Developer</option>
                <option value="AI Engineer">AI Engineer</option>
                <option value="Cyber Security">Cyber Security</option>
                <option value="Cloud Engineer">Cloud Engineer</option>
                <option value="Data Scientist">Data Scientist</option>
              </select>
            </div>
          </div>

          <!-- Skills Selector -->
          <div class="form-group col-span-2">
            <label for="skills">Current Skills <span class="label-hint">(Select multiple from the list below)</span></label>
            
            <!-- Hidden input to hold comma-separated values for backend compatibility -->
            <input type="hidden" id="skills" name="skills" value="">
            
            <!-- Clickable Skill Tags Container -->
            <div class="skills-selector-container">
              <!-- Categories of Skills -->
              <div class="skill-category">
                <h5>Languages</h5>
                <div class="skills-tags-list">
                  <% const languages = ['HTML', 'CSS', 'JavaScript', 'TypeScript', 'Python', 'Java', 'C++', 'Go', 'Rust', 'SQL']; %>
                  <% languages.forEach(skill => { %>
                    <span class="skill-tag-badge" data-skill="<%= skill %>">
                      <%= skill %>
                    </span>
                  <% }); %>
                </div>
              </div>

              <div class="skill-category">
                <h5>Web Development</h5>
                <div class="skills-tags-list">
                  <% const web = ['React', 'Node.js', 'Express.js', 'MongoDB', 'Tailwind CSS', 'Bootstrap', 'REST APIs', 'GraphQL']; %>
                  <% web.forEach(skill => { %>
                    <span class="skill-tag-badge" data-skill="<%= skill %>">
                      <%= skill %>
                    </span>
                  <% }); %>
                </div>
              </div>

              <div class="skill-category">
                <h5>Data Science & AI</h5>
                <div class="skills-tags-list">
                  <% const data = ['Pandas', 'NumPy', 'Machine Learning', 'Deep Learning', 'PyTorch', 'TensorFlow', 'Statistics']; %>
                  <% data.forEach(skill => { %>
                    <span class="skill-tag-badge" data-skill="<%= skill %>">
                      <%= skill %>
                    </span>
                  <% }); %>
                </div>
              </div>

              <div class="skill-category">
                <h5>DevOps & Cloud</h5>
                <div class="skills-tags-list">
                  <% const devops = ['Git', 'GitHub', 'Docker', 'Kubernetes', 'AWS', 'Linux', 'Vercel', 'Netlify']; %>
                  <% devops.forEach(skill => { %>
                    <span class="skill-tag-badge" data-skill="<%= skill %>">
                      <%= skill %>
                    </span>
                  <% }); %>
                </div>
              </div>

              <div class="skill-category">
                <h5>Cybersecurity</h5>
                <div class="skills-tags-list">
                  <% const cyber = ['Network Security', 'Cryptography', 'Pentesting', 'OWASP', 'Wireshark', 'Metasploit']; %>
                  <% cyber.forEach(skill => { %>
                    <span class="skill-tag-badge" data-skill="<%= skill %>">
                      <%= skill %>
                    </span>
                  <% }); %>
                </div>
              </div>
            </div>

            <!-- Custom Skill Input -->
            <div class="custom-skill-adder">
              <input type="text" id="custom-skill-input" placeholder="Type a custom skill...">
              <button type="button" id="add-custom-skill-btn" class="btn btn-secondary btn-sm">Add Skill</button>
            </div>
            
            <p class="form-hint-text">Add custom skills above, or click on predefined tags to toggle selection. They will automatically sync with your learning roadmap progress.</p>
          </div>

          <!-- Interests -->
          <div class="form-group col-span-2">
            <label for="interests">Interests <span class="label-hint">(Comma-separated list)</span></label>
            <div class="input-wrapper">
              <i class="fa-solid fa-heart"></i>
              <input type="text" id="interests" name="interests" placeholder="e.g. Open Source, Machine Learning, Web Design, Blogging">
            </div>
          </div>

          <!-- Daily Study Hours -->
          <div class="form-group">
            <label for="dailyStudyHours">Daily Study Hours</label>
            <div class="input-wrapper">
              <i class="fa-solid fa-clock"></i>
              <input type="number" id="dailyStudyHours" name="dailyStudyHours" placeholder="e.g. 4" min="0" max="24">
            </div>
          </div>

        </div>

        <button type="submit" class="btn btn-primary btn-large btn-submit">Save & Go to Dashboard <i class="fa-solid fa-circle-arrow-right"></i></button>
      </form>
    </div>
  </div>
</main>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const skillsInput = document.getElementById('skills');
    const customSkillInput = document.getElementById('custom-skill-input');
    const addCustomSkillBtn = document.getElementById('add-custom-skill-btn');
    const skillsSelectorContainer = document.querySelector('.skills-selector-container');

    // Parse existing skills
    let selectedSkills = skillsInput.value ? skillsInput.value.split(',').map(s => s.trim()).filter(s => s.length > 0) : [];

    // Helper to update the hidden input
    const updateSkillsInput = () => {
      skillsInput.value = selectedSkills.join(', ');
    };

    // Toggle badge click handler
    skillsSelectorContainer.addEventListener('click', (e) => {
      if (e.target.classList.contains('skill-tag-badge')) {
        const skill = e.target.getAttribute('data-skill');
        const skillIndex = selectedSkills.findIndex(s => s.toLowerCase() === skill.toLowerCase().trim());

        if (skillIndex > -1) {
          selectedSkills.splice(skillIndex, 1);
          e.target.classList.remove('selected');
        } else {
          selectedSkills.push(skill);
          e.target.classList.add('selected');
        }
        updateSkillsInput();
      }
    });

    // Add custom skill handler
    const addCustomSkill = () => {
      const customSkill = customSkillInput.value.trim();
      if (!customSkill) return;

      // Check if already exists (case-insensitive)
      const exists = selectedSkills.some(s => s.toLowerCase() === customSkill.toLowerCase());
      if (!exists) {
        selectedSkills.push(customSkill);
        updateSkillsInput();

        // Create a new badge in the Custom skills group
        let customGroup = document.getElementById('custom-skills-group');
        if (!customGroup) {
          customGroup = document.createElement('div');
          customGroup.className = 'skill-category';
          customGroup.id = 'custom-skills-group';
          customGroup.innerHTML = '<h5>Custom Skills</h5><div class="skills-tags-list"></div>';
          skillsSelectorContainer.appendChild(customGroup);
        }
        const tagsList = customGroup.querySelector('.skills-tags-list');
        const newBadge = document.createElement('span');
        newBadge.className = 'skill-tag-badge selected';
        newBadge.setAttribute('data-skill', customSkill);
        newBadge.innerText = customSkill;
        tagsList.appendChild(newBadge);
      }
      customSkillInput.value = '';
    };

    addCustomSkillBtn.addEventListener('click', addCustomSkill);
    customSkillInput.addEventListener('keypress', (e) => {
      if (e.key === 'Enter') {
        e.preventDefault();
        addCustomSkill();
      }
    });
  });
</script>

<%- include('partials/footer') %>
