<%- include('partials/header') %>
<%- include('partials/navbar') %>

<div class="container social-page">
  <% if (typeof success !== 'undefined' && success) { %>
    <div class="alert alert-success alert-dismissible" style="margin-bottom: 20px;">
      <i class="fa-solid fa-circle-check"></i>
      <span><%= success %></span>
    </div>
  <% } %>

  <% if (typeof error !== 'undefined' && error) { %>
    <div class="alert alert-danger alert-dismissible" style="margin-bottom: 20px;">
      <i class="fa-solid fa-triangle-exclamation"></i>
      <span><%= error %></span>
    </div>
  <% } %>

  <div class="social-hero">
    <h1><i class="fa-solid fa-users"></i> Student Community</h1>
    <p>Explore developer profiles, compare coding platforms progress, and connect with peers.</p>
  </div>

  <div class="social-grid">
    <!-- Left Column: Personal Social Card -->
    <aside class="social-sidebar">
      <div class="card my-social-card">
        <div class="card-header">
          <h3><i class="fa-solid fa-circle-user"></i> Connected Identity</h3>
        </div>
        <div class="card-body">
          <div class="my-profile-brief">
            <div class="avatar-stub">
              <%= user.profile.fullName ? user.profile.fullName.split(' ').map(n => n[0]).join('') : 'U' %>
            </div>
            <div class="brief-info">
              <h4><%= user.profile.fullName || 'Student User' %></h4>
              <span><%= user.profile.careerGoal || 'Not set' %></span>
            </div>
          </div>

          <div class="my-social-stats">
            <!-- GitHub Box -->
            <div class="my-social-stat-box">
              <div class="stat-box-platform github" style="display: flex; justify-content: space-between; align-items: center; width: 100%;">
                <div>
                  <i class="fa-brands fa-github"></i>
                  <span>GitHub</span>
                </div>
                <% if (user.profile.githubUsername) { %>
                  <form action="/profile/disconnect" method="POST" style="margin: 0;">
                    <input type="hidden" name="platform" value="github">
                    <button type="submit" class="btn-disconnect-social" style="padding: 2px 6px; font-size: 10px;" title="Disconnect GitHub"><i class="fa-solid fa-link-slash"></i></button>
                  </form>
                <% } %>
              </div>
              
              <% if (user.profile.githubUsername) { %>
                <div class="stat-box-data">
                  <div class="stat-data-item">
                    <span class="stat-val">34</span>
                    <span class="stat-lbl">Repos</span>
                  </div>
                  <div class="stat-data-item">
                    <span class="stat-val">18</span>
                    <span class="stat-lbl">Stars</span>
                  </div>
                </div>
                <div class="stat-box-user">@<%= user.profile.githubUsername %></div>
              <% } else { %>
                <div class="stat-box-empty">
                  <button type="button" class="btn btn-connect-social" onclick="toggleConnectForm('github')" style="font-size: 11px; width: 100%; text-align: center; justify-content: center;"><i class="fa-solid fa-link"></i> Connect GitHub</button>
                  <div id="connect-form-github" class="social-connect-inline-form" style="display: none; margin-top: 8px; padding: 6px;">
                    <form action="/profile/connect" method="POST">
                      <input type="hidden" name="platform" value="github">
                      <div class="social-input-group">
                        <input type="text" name="username" placeholder="GitHub username" required style="padding: 4px 6px; font-size: 11px;">
                        <button type="submit" class="btn btn-primary btn-xs" style="padding: 2px 6px;">Link</button>
                        <button type="button" class="btn btn-secondary btn-xs" onclick="toggleConnectForm('github')" style="padding: 2px 6px;"><i class="fa-solid fa-xmark"></i></button>
                      </div>
                    </form>
                  </div>
                </div>
              <% } %>
            </div>

            <!-- LeetCode Box -->
            <div class="my-social-stat-box">
              <div class="stat-box-platform leetcode" style="display: flex; justify-content: space-between; align-items: center; width: 100%;">
                <div>
                  <i class="fa-solid fa-code"></i>
                  <span>LeetCode</span>
                </div>
                <% if (user.profile.leetcodeUsername) { %>
                  <form action="/profile/disconnect" method="POST" style="margin: 0;">
                    <input type="hidden" name="platform" value="leetcode">
                    <button type="submit" class="btn-disconnect-social" style="padding: 2px 6px; font-size: 10px;" title="Disconnect LeetCode"><i class="fa-solid fa-link-slash"></i></button>
                  </form>
                <% } %>
              </div>
              
              <% if (user.profile.leetcodeUsername) { %>
                <div class="stat-box-data">
                  <div class="stat-data-item">
                    <span class="stat-val">128</span>
                    <span class="stat-lbl">Solved</span>
                  </div>
                  <div class="stat-data-item">
                    <span class="stat-val">Top 15%</span>
                    <span class="stat-lbl">Rank</span>
                  </div>
                </div>
                <div class="stat-box-user">@<%= user.profile.leetcodeUsername %></div>
              <% } else { %>
                <div class="stat-box-empty">
                  <button type="button" class="btn btn-connect-social" onclick="toggleConnectForm('leetcode')" style="font-size: 11px; width: 100%; text-align: center; justify-content: center;"><i class="fa-solid fa-link"></i> Connect LeetCode</button>
                  <div id="connect-form-leetcode" class="social-connect-inline-form" style="display: none; margin-top: 8px; padding: 6px;">
                    <form action="/profile/connect" method="POST">
                      <input type="hidden" name="platform" value="leetcode">
                      <div class="social-input-group">
                        <input type="text" name="username" placeholder="LeetCode username" required style="padding: 4px 6px; font-size: 11px;">
                        <button type="submit" class="btn btn-primary btn-xs" style="padding: 2px 6px;">Link</button>
                        <button type="button" class="btn btn-secondary btn-xs" onclick="toggleConnectForm('leetcode')" style="padding: 2px 6px;"><i class="fa-solid fa-xmark"></i></button>
                      </div>
                    </form>
                  </div>
                </div>
              <% } %>
            </div>
          </div>
        </div>
      </div>
    </aside>

    <!-- Right Column: Student Cards List -->
    <main class="social-main">
      <div class="social-list-header">
        <h2>Peer Directories (<%= students.length %>)</h2>
      </div>

      <div class="students-grid">
        <% students.forEach(student => { %>
          <div class="student-card <%= student._id === user._id ? 'current-student-card' : '' %>">
            <% if (student._id === user._id) { %>
              <span class="self-tag">You</span>
            <% } %>
            
            <div class="student-card-top">
              <div class="student-avatar">
                <%= student.profile.fullName ? student.profile.fullName.split(' ').map(n => n[0]).join('') : 'U' %>
              </div>
              <div class="student-primary-info">
                <h4><%= student.profile.fullName %></h4>
                <p class="student-college"><%= student.profile.collegeName %> • <%= student.profile.branch %></p>
                <span class="goal-badge"><%= student.profile.careerGoal %></span>
              </div>
            </div>

            <div class="student-card-details">
              <div class="student-meta-item">
                <span class="meta-label">CGPA</span>
                <span class="meta-value"><%= student.profile.cgpa %></span>
              </div>
              <div class="student-meta-item">
                <span class="meta-label">Year</span>
                <span class="meta-value"><%= student.profile.currentYear %></span>
              </div>
              <div class="student-meta-item">
                <span class="meta-label">Study Time</span>
                <span class="meta-value"><%= student.profile.dailyStudyHours || 'N/A' %> hrs</span>
              </div>
            </div>

            <!-- Connected Accounts Icons & Stats Toggle -->
            <div class="student-card-socials">
              <% if (student.profile.githubUsername) { %>
                <div class="student-social-btn" onclick="toggleStudentSocialStats('<%= student._id %>', 'github')" title="View GitHub stats">
                  <i class="fa-brands fa-github"></i>
                  <span>@<%= student.profile.githubUsername %></span>
                </div>
              <% } %>

              <% if (student.profile.leetcodeUsername) { %>
                <div class="student-social-btn" onclick="toggleStudentSocialStats('<%= student._id %>', 'leetcode')" title="View LeetCode stats">
                  <i class="fa-solid fa-code"></i>
                  <span>@<%= student.profile.leetcodeUsername %></span>
                </div>
              <% } %>

              <% if (!student.profile.githubUsername && !student.profile.leetcodeUsername) { %>
                <span class="no-socials-label">No accounts linked</span>
              <% } %>
            </div>

            <!-- Hidden Social stats panels (Toggled on click) -->
            <% if (student.profile.githubUsername) { %>
              <div id="social-stats-<%= student._id %>-github" class="student-social-stats-panel github-panel" style="display: none;">
                <h5><i class="fa-brands fa-github"></i> GitHub Account</h5>
                <div class="social-stats-row">
                  <div><strong><%= student.socialStats.githubRepos %></strong> Repos</div>
                  <div><strong><%= student.socialStats.githubStars %></strong> Stars</div>
                  <div><strong>@<%= student.profile.githubUsername %></strong></div>
                </div>
              </div>
            <% } %>

            <% if (student.profile.leetcodeUsername) { %>
              <div id="social-stats-<%= student._id %>-leetcode" class="student-social-stats-panel leetcode-panel" style="display: none;">
                <h5><i class="fa-solid fa-code"></i> LeetCode Account</h5>
                <div class="social-stats-row">
                  <div><strong><%= student.socialStats.leetcodeSolved %></strong> Solved</div>
                  <div><strong>#<%= student.socialStats.leetcodeRank.toLocaleString() %></strong> Rank</div>
                  <div><strong>@<%= student.profile.leetcodeUsername %></strong></div>
                </div>
              </div>
            <% } %>

          </div>
        <% }) %>
      </div>
    </main>
  </div>
</div>

<%- include('partials/footer') %>
