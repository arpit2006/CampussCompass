<%- include('partials/header') %>
<%- include('partials/navbar') %>

<main class="dashboard-page">
  <div class="dashboard-container">
    
    <% if (typeof success !== 'undefined' && success) { %>
      <div class="alert alert-success alert-dismissible">
        <i class="fa-solid fa-circle-check"></i>
        <span><%= success %></span>
      </div>
    <% } %>

    <!-- Welcome Card -->
    <section class="welcome-card">
      <div class="welcome-text-content">
        <h1>Welcome Back, <span class="text-gradient"><%= user.profile.fullName %></span>!</h1>
        <p>Your learning compass is pointing towards becoming a <strong><%= user.profile.careerGoal %></strong>. Keep learning and updating your skills to track your progress!</p>
      </div>
      <div class="welcome-badge">
        <i class="fa-solid fa-compass compass-logo"></i>
      </div>
    </section>

    <!-- Tab Switcher -->
    <div class="dashboard-tabs-container">
      <div class="dashboard-tabs">
        <button class="db-tab-btn active" data-tab="roadmap"><i class="fa-solid fa-route"></i> Roadmap Timeline</button>
        <button class="db-tab-btn" data-tab="resources"><i class="fa-solid fa-book"></i> Resource Library</button>
      </div>
    </div>

    <div class="dashboard-grid">
      
      <!-- Left Column: Student Information & Progress -->
      <aside class="dashboard-sidebar">
        
        <!-- Student Info Card -->
        <div class="card student-info-card">
          <div class="card-header">
            <h3><i class="fa-solid fa-user-graduate"></i> Student Profile</h3>
            <a href="/profile" class="edit-link" title="Edit Profile"><i class="fa-solid fa-pen-to-square"></i> Edit</a>
          </div>
          <div class="card-body">
            <ul class="info-list">
              <li>
                <span class="info-label">College:</span>
                <span class="info-value"><%= user.profile.collegeName %></span>
              </li>
              <li>
                <span class="info-label">Branch:</span>
                <span class="info-value"><%= user.profile.branch %></span>
              </li>
              <li>
                <span class="info-label">Current Year:</span>
                <span class="info-value"><%= user.profile.currentYear %></span>
              </li>
              <li>
                <span class="info-label">CGPA:</span>
                <span class="info-value"><%= user.profile.cgpa ? user.profile.cgpa.toFixed(2) : 'Not Specified' %></span>
              </li>
              <li>
                <span class="info-label">Study Time:</span>
                <span class="info-value"><%= user.profile.dailyStudyHours ? user.profile.dailyStudyHours + ' hours/day' : 'Not Specified' %></span>
              </li>
            </ul>

            <div class="skills-interests-section">
              <h4>Skills</h4>
              <div class="tag-container">
                <% if (user.profile.skills && user.profile.skills.length > 0) { %>
                  <% user.profile.skills.forEach(skill => { %>
                    <span class="tag tag-skill"><%= skill %></span>
                  <% }) %>
                <% } else { %>
                  <span class="no-tags">No skills listed yet. Add skills in profile to track progress.</span>
                <% } %>
              </div>
            </div>

            <div class="skills-interests-section">
              <h4>Interests</h4>
              <div class="tag-container">
                <% if (user.profile.interests && user.profile.interests.length > 0) { %>
                  <% user.profile.interests.forEach(interest => { %>
                    <span class="tag tag-interest"><%= interest %></span>
                  <% }) %>
                <% } else { %>
                  <span class="no-tags">No interests listed.</span>
                <% } %>
              </div>
            </div>
          </div>
        </div>

        <!-- Progress Tracker Card -->
        <div class="card progress-card">
          <div class="card-header">
            <h3><i class="fa-solid fa-chart-line"></i> Roadmap Progress</h3>
          </div>
          <div class="card-body">
            <div class="progress-radial-container">
              <div class="progress-bar-linear">
                <div class="progress-bar-fill" style="width: <%= progress.percent %>%;"></div>
              </div>
              <div class="progress-stats">
                <span class="progress-percentage"><%= progress.percent %>%</span>
                <span class="progress-fraction"><%= progress.completedCount %> of <%= progress.totalCount %> topics completed</span>
              </div>
            </div>
            <p class="progress-tip">
              <i class="fa-solid fa-lightbulb"></i> Tip: Acquire new skills listed in the roadmap below and add them to your profile to mark them complete!
            </p>
          </div>
        </div>

      </aside>

      <!-- Right Column: Curated Roadmap timeline -->
      <section class="dashboard-main db-tab-pane active" id="db-pane-roadmap">
        <div class="card roadmap-container-card">
          <div class="card-header roadmap-header-section">
            <div>
              <span class="roadmap-badge-tag"><%= user.profile.careerGoal %> Path</span>
              <h2>Recommended Roadmap</h2>
            </div>
            <div class="roadmap-icon-right">
              <i class="fa-solid fa-route"></i>
            </div>
          </div>
          
          <div class="card-body">
            <% if (roadmap) { %>
              <p class="roadmap-desc-para"><%= roadmap.description %></p>

              <!-- Semester Horizontal Tab Selector -->
              <div class="semester-tab-bar">
                <% roadmap.semesters.forEach((sem, sIndex) => { %>
                  <button class="sem-tab-btn <%= sIndex === 0 ? 'active' : '' %>" data-sem="<%= sIndex %>">
                    Sem <%= sIndex + 1 %>
                  </button>
                <% }) %>
              </div>
              
              <!-- Tabbed Semester Panes -->
              <div class="semester-panes">
                <% roadmap.semesters.forEach((sem, sIndex) => { %>
                  <div class="semester-pane <%= sIndex === 0 ? 'active' : '' %>" id="sem-pane-<%= sIndex %>">
                    <div class="semester-pane-header">
                      <h3><%= sem.semester %> Focus Checklist</h3>
                    </div>
                    
                    <div class="semester-topics">
                      <% sem.topics.forEach((topic, tIndex) => { %>
                        <div class="topic-item <%= topic.isCompleted ? 'completed-topic' : '' %>">
                          <div class="topic-indicator">
                            <% if (topic.isCompleted) { %>
                              <i class="fa-solid fa-circle-check completed-icon"></i>
                            <% } else { %>
                              <i class="fa-regular fa-circle pending-icon"></i>
                            <% } %>
                          </div>
                          
                          <div class="topic-card">
                            <div class="topic-card-header">
                              <h4><%= topic.name %></h4>
                              <% if (topic.isCompleted) { %>
                                <span class="badge badge-success"><i class="fa-solid fa-check"></i> Completed</span>
                              <% } else { %>
                                <span class="badge badge-pending">To Do</span>
                              <% } %>
                            </div>
                            <p class="topic-desc"><%= topic.description %></p>
                            
                            <% if (topic.resources && topic.resources.length > 0) { %>
                              <div class="topic-resources">
                                <h5>Recommended Resources:</h5>
                                <ul>
                                  <% topic.resources.forEach(resource => { %>
                                    <li>
                                      <i class="fa-solid fa-link"></i> 
                                      <% if (resource.includes('(')) { 
                                         const linkName = resource.substring(0, resource.indexOf('(')).trim();
                                         const linkDetail = resource.substring(resource.indexOf('('));
                                      %>
                                        <span><%= linkName %></span> <span class="resource-detail"><%= linkDetail %></span>
                                      <% } else { %>
                                        <span><%= resource %></span>
                                      <% } %>
                                    </li>
                                  <% }) %>
                                </ul>
                              </div>
                            <% } %>
                          </div>
                        </div>
                      <% }) %>
                    </div>
                  </div>
                <% }) %>
              </div>

            <% } else { %>
              <div class="no-roadmap-error">
                <i class="fa-solid fa-circle-exclamation"></i>
                <p>Sorry, we could not load the roadmap for "<%= user.profile.careerGoal %>". Please contact administration or check data files.</p>
              </div>
            <% } %>
          </div>
        </div>
      </section>

      <!-- Right Column: Curated Resource Library -->
      <section class="dashboard-main db-tab-pane" id="db-pane-resources">
        <div class="card roadmap-container-card">
          <div class="card-header roadmap-header-section">
            <div>
              <span class="roadmap-badge-tag"><%= user.profile.careerGoal %> Path</span>
              <h2>Curated Resource Library</h2>
            </div>
            <div class="roadmap-icon-right">
              <i class="fa-solid fa-book"></i>
            </div>
          </div>
          
          <div class="card-body">
            <p class="roadmap-desc-para">Here is a curated collection of learning guides, cheatsheets, and coding sheets to help you progress in your track.</p>
            
            <div class="resources-grid-db" style="margin-top: 24px;">
              <!-- Resource Card 1 -->
              <div class="card resource-card-wrapper" style="position: relative; border: 2px solid var(--border-dark); border-radius: var(--radius); padding: 24px; box-shadow: var(--shadow); display: flex; flex-direction: column; min-height: 220px; background-color: var(--surface);">
                <div style="display: flex; flex-direction: column; height: 100%; justify-content: space-between;">
                  <div>
                    <div class="res-icon" style="width: 44px; height: 44px; background: var(--bg-darker); border: 1px solid var(--border-dark); border-radius: var(--radius); display: flex; align-items: center; justify-content: center; color: var(--primary); font-size: 18px; margin-bottom: 18px;"><i class="fa-solid fa-file-pdf"></i></div>
                    <h3 style="font-size: 17px; font-weight: 700; margin-bottom: 8px; color: var(--text);">Git &amp; GitHub Cheatsheet</h3>
                    <p style="font-size: 13px; color: var(--text-muted); line-height: 1.5; margin-bottom: 16px;">Vetted collection of commands, branching flows, and best practices for developers.</p>
                  </div>
                  <div style="border-top: 1px dashed var(--border); padding-top: 12px; display: flex; justify-content: space-between; align-items: center; margin-top: auto;">
                    <span style="font-size: 11px; font-weight: 700; color: var(--secondary); text-transform: uppercase;">PDF Guide &bull; 5 mins read</span>
                    <a href="https://github.github.com/training-kit/downloads/github-git-cheat-sheet.pdf" target="_blank" class="btn btn-primary" style="font-size: 11px; padding: 6px 14px; box-shadow: 2px 2px 0 var(--border-dark);"><i class="fa-solid fa-file-arrow-down"></i> Download</a>
                  </div>
                </div>
              </div>

              <!-- Resource Card 2 -->
              <div class="card resource-card-wrapper" style="position: relative; border: 2px solid var(--border-dark); border-radius: var(--radius); padding: 24px; box-shadow: var(--shadow); display: flex; flex-direction: column; min-height: 220px; background-color: var(--surface);">
                <div style="display: flex; flex-direction: column; height: 100%; justify-content: space-between;">
                  <div>
                    <div class="res-icon" style="width: 44px; height: 44px; background: var(--bg-darker); border: 1px solid var(--border-dark); border-radius: var(--radius); display: flex; align-items: center; justify-content: center; color: var(--primary); font-size: 18px; margin-bottom: 18px;"><i class="fa-solid fa-video"></i></div>
                    <h3 style="font-size: 17px; font-weight: 700; margin-bottom: 8px; color: var(--text);">Vetted Video Playlists</h3>
                    <p style="font-size: 13px; color: var(--text-muted); line-height: 1.5; margin-bottom: 16px;">Curated list of premium YouTube video series on DSA, Web Dev, and Machine Learning.</p>
                  </div>
                  <div style="border-top: 1px dashed var(--border); padding-top: 12px; display: flex; justify-content: space-between; align-items: center; margin-top: auto;">
                    <span style="font-size: 11px; font-weight: 700; color: var(--secondary); text-transform: uppercase;">Videos &bull; 20+ Hours</span>
                    <a href="/playlists" class="btn btn-primary" style="font-size: 11px; padding: 6px 14px; box-shadow: 2px 2px 0 var(--border-dark);"><i class="fa-solid fa-up-right-from-square"></i> Open Playlists</a>
                  </div>
                </div>
              </div>

              <!-- Resource Card 3 -->
              <div class="card resource-card-wrapper" style="position: relative; border: 2px solid var(--border-dark); border-radius: var(--radius); padding: 24px; box-shadow: var(--shadow); display: flex; flex-direction: column; min-height: 220px; background-color: var(--surface);">
                <div style="display: flex; flex-direction: column; height: 100%; justify-content: space-between;">
                  <div>
                    <div class="res-icon" style="width: 44px; height: 44px; background: var(--bg-darker); border: 1px solid var(--border-dark); border-radius: var(--radius); display: flex; align-items: center; justify-content: center; color: var(--primary); font-size: 18px; margin-bottom: 18px;"><i class="fa-solid fa-code"></i></div>
                    <h3 style="font-size: 17px; font-weight: 700; margin-bottom: 8px; color: var(--text);">DSA Practice Sheets</h3>
                    <p style="font-size: 13px; color: var(--text-muted); line-height: 1.5; margin-bottom: 16px;">Complete topic-wise LeetCode problems curated specifically for college placement preparation.</p>
                  </div>
                  <div style="border-top: 1px dashed var(--border); padding-top: 12px; display: flex; justify-content: space-between; align-items: center; margin-top: auto;">
                    <span style="font-size: 11px; font-weight: 700; color: var(--secondary); text-transform: uppercase;">Coding Sheet &bull; 150+ Problems</span>
                    <a href="https://neetcode.io/practice" target="_blank" class="btn btn-primary" style="font-size: 11px; padding: 6px 14px; box-shadow: 2px 2px 0 var(--border-dark);"><i class="fa-solid fa-up-right-from-square"></i> Open NeetCode</a>
                  </div>
                </div>
              </div>

              <!-- Resource Card 4 -->
              <div class="card resource-card-wrapper" style="position: relative; border: 2px solid var(--border-dark); border-radius: var(--radius); padding: 24px; box-shadow: var(--shadow); display: flex; flex-direction: column; min-height: 220px; background-color: var(--surface);">
                <div style="display: flex; flex-direction: column; height: 100%; justify-content: space-between;">
                  <div>
                    <div class="res-icon" style="width: 44px; height: 44px; background: var(--bg-darker); border: 1px solid var(--border-dark); border-radius: var(--radius); display: flex; align-items: center; justify-content: center; color: var(--primary); font-size: 18px; margin-bottom: 18px;"><i class="fa-solid fa-laptop-code"></i></div>
                    <h3 style="font-size: 17px; font-weight: 700; margin-bottom: 8px; color: var(--text);">Project Reference Codes</h3>
                    <p style="font-size: 13px; color: var(--text-muted); line-height: 1.5; margin-bottom: 16px;">Open-source boilerplates and sample repositories to kickstart your portfolio projects.</p>
                  </div>
                  <div style="border-top: 1px dashed var(--border); padding-top: 12px; display: flex; justify-content: space-between; align-items: center; margin-top: auto;">
                    <span style="font-size: 11px; font-weight: 700; color: var(--secondary); text-transform: uppercase;">Source Code &bull; 8 Repositories</span>
                    <a href="https://github.com/explore" target="_blank" class="btn btn-primary" style="font-size: 11px; padding: 6px 14px; box-shadow: 2px 2px 0 var(--border-dark);"><i class="fa-solid fa-up-right-from-square"></i> Browse GitHub</a>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

    </div>
  </div>
</main>

<%- include('partials/footer') %>
